{
  "name": "ai-switch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.12.4",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "tauri:dev": "tauri dev",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "release:manifest:test": "node --test scripts/create-updater-manifest.test.mjs",
    "rust:check": "cd src-tauri && cargo check",
    "rust:test": "cd src-tauri && cargo test",
    "server:build": "cd src-tauri && cargo build --bin ai-switch-server",
    "server:build:release": "cd src-tauri && cargo build --release --bin ai-switch-server",
    "server:check": "cd src-tauri && cargo check --bin ai-switch-server",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.51.1",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-process": "^2.3.0",
    "@tauri-apps/plugin-updater": "^2.9.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "ocrad.js": "^0.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.5.4",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "jsdom": "^25.0.1",
    "typescript": "^5.5.4",
    "unocss": "^66.7.5",
    "vite": "^5.4.2",
    "vitest": "^2.0.5"
  }
}
