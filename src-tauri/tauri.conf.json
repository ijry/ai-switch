{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AI Switch",
  "version": "0.1.0",
  "identifier": "io.xyito.ai-switch",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AI Switch",
        "width": 1180,
        "height": 760,
        "minWidth": 960,
        "minHeight": 640
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": {
      "../dist": "web/"
    },
    "externalBin": [
      "binaries/ai-switch-tsnet"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/ijry/ai-switch/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVBNjZBRjAyRjA0MzNGN0UKUldSK1AwUHdBcTltNnFSbmQybDJjeUJEcGJ4OVRrbXZLWEZJNWRSd0Rud0tpdENkWDQ2RldwK24K"
    }
  }
}
